{
  "name": "design-os-navigator",
  "displayName": "Design Os",
  "description": "Visual node graph navigator for Design Operating System projects",
  "version": "0.7.1",
  "publisher": "MehdiVilquin",
  "repository": {
    "type": "git",
    "url": "https://github.com/MehdiVilquin/design-os-navigator"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "workspaceContains:CLAUDE.md",
    "workspaceContains:.claude/context.md",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Design OS",
      "properties": {
        "designOs.actionTarget": {
          "type": "string",
          "enum": ["cursor", "terminal"],
          "default": "cursor",
          "description": "When you click an action in the Navigator: 'cursor' copies the command to clipboard and prompts you to paste in Cursor chat/Composer; 'terminal' runs the command in the Claude CLI terminal."
        }
      }
    },
    "commands": [
      {
        "command": "designOs.openNavigator",
        "title": "Design OS: Open Navigator",
        "icon": "$(compass)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "design-os",
          "title": "Design OS",
          "icon": "$(compass)"
        }
      ]
    },
    "views": {
      "design-os": [
        {
          "type": "webview",
          "id": "designOsConsole",
          "name": "Console"
        }
      ]
    }
  },
  "scripts": {
    "compile": "npm run compile:ext && npm run compile:webview",
    "compile:ext": "node esbuild.config.mjs",
    "compile:webview": "vite build",
    "watch": "npm run watch:ext",
    "watch:ext": "node esbuild.config.mjs --watch",
    "watch:webview": "vite build --watch",
    "dev": "concurrently \"npm run watch:ext\" \"npm run watch:webview\"",
    "build": "npm run compile:ext -- --production && npm run compile:webview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext ts,tsx",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.webview.json --noEmit"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0",
    "@vitest/coverage-v8": "^1.2.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0"
  }
}
